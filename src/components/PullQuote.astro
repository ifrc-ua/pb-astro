---
// Велика врізка (pull-quote) з рядків `> ВРІЗКА:` канону.
// Phenomena, ліва лінія-акцент кольору бренду. Текст — у слоті.
---
<blockquote class="pull-quote">
  <p><slot /></p>
</blockquote>

<style>
  .pull-quote {
    max-width: 680px;
    margin: 2.2rem auto;
    padding: 18px 24px;
    border-left: 4px solid var(--brand);
    border-radius: 0 12px 12px 0;
    /* Ледь жовтий фон — врізка відділяється від потоку тексту */
    background: #fff9e8;
  }
  /* Нічна тема: той самий «теплий» тон, але темний — світлий фон з'їв би контраст */
  :global(:root[data-theme="dark"]) .pull-quote {
    background: color-mix(in srgb, #ffec08 7%, var(--canvas));
  }
  .pull-quote p {
    margin: 0;
    font-family: "Phenomena", "Inter Variable", sans-serif;
    font-weight: 700;
    font-size: clamp(24px, 4.2vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-wrap: balance;
  }
</style>
