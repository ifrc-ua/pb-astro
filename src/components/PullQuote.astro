---
// Велика врізка (pull-quote) з рядків `> ВРІЗКА:` канону.
// Формат як у публікації на КУРСі: світла панель, жовта смуга-акцент зліва,
// жирний текст основним шрифтом. Текст — у слоті.
---
<blockquote class="pull-quote">
  <p><slot /></p>
</blockquote>

<style>
  .pull-quote {
    max-width: 680px;
    margin: 2.2rem auto;
    padding: 22px 28px;
    border-left: 6px solid var(--accent);
    border-radius: 0 16px 16px 0;
    background: var(--panel);
  }
  .pull-quote p {
    margin: 0;
    font-weight: 700;
    font-size: clamp(19px, 3vw, 24px);
    line-height: 1.35;
    color: var(--ink);
    text-wrap: balance;
  }
</style>
