---
// Футер сайту: контактна пошта і соцмережі видавця (ІФ регіональний центр).
// Іконки — власні інлайн-SVG (self-hosted, без CDN), монохром через currentColor,
// тач-цілі ≥44px (design.md §8). Рядок «Знайшли помилку…» перенесено з фіналу
// статті сюди — одне місце контакту, без дублю.
const socials = [
  {
    href: "https://github.com/ifrc-ua",
    label: "GitHub",
    path: "M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-1.94c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.35.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11.04 11.04 0 0 1 5.77 0c2.2-1.49 3.16-1.18 3.16-1.18.63 1.59.24 2.76.12 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.78 1.05.78 2.13v3.15c0 .3.2.66.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z",
  },
  {
    href: "https://www.facebook.com/if.regional.center",
    label: "Facebook",
    path: "M13.6 21.5v-8.4h2.82l.42-3.27H13.6V7.74c0-.95.26-1.59 1.62-1.59h1.73V3.22c-.3-.04-1.33-.13-2.52-.13-2.5 0-4.2 1.52-4.2 4.32v2.42H7.4v3.27h2.83v8.4h3.37z",
  },
  {
    href: "https://www.linkedin.com/company/ifrc-ua/",
    label: "LinkedIn",
    path: "M5.06 3.5a2.28 2.28 0 1 1-.02 4.56 2.28 2.28 0 0 1 .02-4.56zM3.1 9.25h3.93V21H3.1zM9.1 9.25h3.77v1.6h.05c.53-.99 1.81-2.04 3.72-2.04 3.98 0 4.72 2.62 4.72 6.03V21h-3.93v-5.46c0-1.3-.03-2.98-1.82-2.98-1.82 0-2.1 1.42-2.1 2.88V21H9.1z",
  },
];
---
<footer class="site-footer">
  <div class="foot-inner">
    <p class="foot-author">
      Авторка — <a href="https://www.linkedin.com/in/nataliia-kobylchak" target="_blank" rel="noopener">Наталія Кобильчак</a>
    </p>
    <span class="foot-mail">
      <!-- зафарбований конвертик — та сама вага, що в суцільних соціконок праворуч -->
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z" />
      </svg>
      <span>od[@]ifrc.org.ua</span>
    </span>
    <nav class="foot-social" aria-label="Ми в соцмережах">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
            <path d={s.path} />
          </svg>
        </a>
      ))}
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 64px;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }
  .foot-inner {
    max-width: 680px;
    margin-inline: auto;
    padding: 20px 24px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 4px 24px;
  }
  /* Авторка — окремим рядком над контактами; лінк на LinkedIn з тап-паддінгом
     ≥44px (design.md §8), як у підписів віджетів */
  .foot-author {
    flex-basis: 100%;
    margin: 0;
    font-size: 15px;
    color: var(--muted);
  }
  .foot-author a {
    display: inline-block;
    padding: 13px 4px;
    margin-block: -9px;
  }
  .foot-mail {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 44px;
    padding-block: 4px;
    font-size: 15px;
    color: var(--muted);
  }
  .foot-social {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  /* Іконка-кнопка: тач-ціль 44×44, ховер як ghost-кнопка дизайн-системи;
     без крапчастого підкреслення — лінк суто іконковий */
  .foot-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms ease-out, background-color 150ms ease-out;
  }
  .foot-social a:hover, .foot-social a:focus-visible {
    color: var(--link);
    background: var(--panel);
  }
  .foot-social a:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 2px;
  }
</style>
