---
// Розкривний блок статті (нативний <details>, читабельний без JS).
// Стиль-референс — CLEANUP-LOG; оформлення токенами дизайн-системи.
// Жовтий маркер-трикутник — завжди з ink-обводкою (design.md §7).
interface Props { summary: string; open?: boolean }
const { summary, open = false } = Astro.props;
---
<details class="pb-box" open={open}>
  <summary>{summary}</summary>
  <div class="pb-box__body"><slot /></div>
</details>

<style>
  .pb-box {
    max-width: 680px;
    margin: 1.8rem auto;
    padding: 4px 24px;
    /* Фірмовий фіолетовий з білим текстом — однаковий в обох темах,
       тож токени фіксуємо локально; #FDFDFD на #654EA3 = 6.7:1 AA.
       Лінки — блідо-жовті (secondary-100), інакше на фіолетовому їх не видно. */
    background: #654EA3;
    --ink: #FDFDFD;
    --link: #FFF9B3;
    --line: rgba(253, 253, 253, 0.3);
    color: var(--ink);
    border: 1px solid #4E3C84;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(26, 26, 26, 0.06);
  }
  .pb-box > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 0;
    font-family: "Phenomena", "Inter Variable", sans-serif;
    font-weight: 900;
    font-size: 23px;
    line-height: 1.15;
    letter-spacing: 0.01em;
    color: var(--ink);
  }
  .pb-box > summary::-webkit-details-marker { display: none; }
  /* Трикутник-маркер: жовтий завжди з ink-обводкою #1A1A1A (design.md §7),
     повертається при відкритті */
  .pb-box > summary::before {
    content: "";
    flex: none;
    width: 0; height: 0;
    border-style: solid;
    border-width: 7px 0 7px 11px;
    border-color: transparent transparent transparent var(--accent);
    /* ink-обводка акценту через тонкий drop-shadow по контуру трикутника */
    filter: drop-shadow(0.5px 0 0 #1a1a1a) drop-shadow(-0.5px 0 0 #1a1a1a)
            drop-shadow(0 0.5px 0 #1a1a1a) drop-shadow(0 -0.5px 0 #1a1a1a);
    transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pb-box[open] > summary::before { transform: rotate(90deg); }
  .pb-box__body {
    padding-bottom: 16px;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
  }
  .pb-box__body :global(p) { margin-block: 0.8em; }
  .pb-box__body :global(p:first-child) { margin-top: 0; }
  /* Маркери списків — жовті кружечки з тонкою ink-обводкою (design.md §7:
     жовтий завжди з ink), замість типових крапок */
  .pb-box__body :global(ul) { margin-block: 0.8em; padding-left: 1.5em; list-style: none; }
  .pb-box__body :global(ul li) { margin-block: 0.35em; position: relative; }
  .pb-box__body :global(ul li)::before {
    content: "";
    position: absolute;
    left: -1.25em;
    top: 0.5em;
    width: 9px;
    height: 9px;
    box-sizing: border-box;
    border-radius: 50%;
    background: var(--accent);
    border: 1px solid #1a1a1a;
  }
  /* Фокус на фіолетовому тлі — світлий, брендовий фіолет тут невидимий */
  .pb-box > summary:focus-visible { outline: 2px solid #FFF9B3; outline-offset: 2px; border-radius: 4px; }
</style>
