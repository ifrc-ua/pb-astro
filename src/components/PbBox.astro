---
// Розкривний блок статті (нативний <details>, читабельний без JS).
// Стиль-референс — CLEANUP-LOG; оформлення токенами дизайн-системи.
// Жовтий маркер-трикутник — завжди з ink-обводкою (design.md §7).
interface Props { summary: string; open?: boolean }
const { summary, open = false } = Astro.props;
---
<details class="pb-box" open={open}>
  <summary>{summary}</summary>
  <div class="pb-box__body"><slot /></div>
</details>

<style>
  .pb-box {
    max-width: 680px;
    margin: 1.8rem auto;
    padding: 4px 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
  }
  .pb-box > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 0;
    font-family: "Phenomena", "Inter Variable", sans-serif;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: 0.02em;
    color: var(--ink);
  }
  .pb-box > summary::-webkit-details-marker { display: none; }
  /* Трикутник-маркер: жовтий з ink-обводкою, повертається при відкритті */
  .pb-box > summary::before {
    content: "";
    flex: none;
    width: 0; height: 0;
    border-style: solid;
    border-width: 6px 0 6px 10px;
    border-color: transparent transparent transparent var(--accent);
    /* ink-обводка акценту через тонкий drop-shadow по контуру трикутника */
    filter: drop-shadow(0.5px 0 0 var(--ink)) drop-shadow(-0.5px 0 0 var(--ink))
            drop-shadow(0 0.5px 0 var(--ink)) drop-shadow(0 -0.5px 0 var(--ink));
    transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pb-box[open] > summary::before { transform: rotate(90deg); }
  .pb-box__body {
    padding-bottom: 16px;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
  }
  .pb-box__body :global(p) { margin-block: 0.8em; }
  .pb-box__body :global(p:first-child) { margin-top: 0; }
  .pb-box__body :global(ul) { margin-block: 0.8em; padding-left: 1.4em; }
  .pb-box__body :global(li) { margin-block: 0.35em; }
  .pb-box > summary:focus-visible { outline: 2px solid var(--brand); outline-offset: 2px; border-radius: 4px; }
</style>
